{
  "name": "claude-style-markdown-preview",
  "displayName": "Claude Style Markdown Preview",
  "description": "A markdown preview styled like Claude Code (hybrid serif + sans + mono with Hangul Pretendard fallback). Auto/Light/Dark segmented toggle, heading anchors, code copy, GitHub-flavored admonitions, reading progress, image zoom, floating TOC, and Mermaid diagrams with toolbar.",
  "version": "0.3.0",
  "publisher": "ibank",
  "license": "MIT",
  "author": {
    "name": "ibank",
    "email": "ibank21@gmail.com"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "icon.png",
  "keywords": [
    "markdown",
    "preview",
    "claude",
    "claude code",
    "monospace",
    "terminal",
    "mermaid",
    "theme",
    "admonition",
    "toc",
    "korean",
    "hangul",
    "pretendard"
  ],
  "galleryBanner": {
    "color": "#1a1a1a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ibank/claude-style-markdown-preview.git"
  },
  "bugs": {
    "url": "https://github.com/ibank/claude-style-markdown-preview/issues"
  },
  "homepage": "https://github.com/ibank/claude-style-markdown-preview#readme",
  "contributes": {
    "markdown.previewStyles": [
      "./styles/claude.css"
    ],
    "markdown.previewScripts": [
      "./scripts/theme-toggle.js",
      "./scripts/enhance.js",
      "./scripts/mermaid.min.js",
      "./scripts/mermaid-init.js"
    ]
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
